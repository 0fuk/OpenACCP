{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openacp.dev/schemas/sequence-registry.schema.json",
  "title": "OpenACP Sequence Registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactType",
    "registryId",
    "currentPromptId",
    "latestResponseId",
    "prompts",
    "responses",
    "handoffs",
    "cards",
    "consumes",
    "activeLanes"
  ],
  "properties": {
    "schemaVersion": { "const": "openacp-sequence-registry.v1" },
    "artifactType": { "const": "sequence-registry" },
    "registryId": { "type": "string", "minLength": 1 },
    "currentPromptId": { "type": "string", "minLength": 1 },
    "latestResponseId": { "type": "string", "minLength": 1 },
    "prompts": {
      "type": "array",
      "items": { "type": "object", "required": ["promptId", "path", "role", "status"], "additionalProperties": true }
    },
    "responses": {
      "type": "array",
      "items": { "type": "object", "required": ["responseId", "promptId", "path", "status"], "additionalProperties": true }
    },
    "handoffs": {
      "type": "array",
      "items": { "type": "object", "required": ["handoffId", "taskId", "path", "status"], "additionalProperties": true }
    },
    "cards": {
      "type": "array",
      "items": { "type": "object", "required": ["cardId", "status", "ownerRole"], "additionalProperties": true }
    },
    "consumes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["consumeId", "responseId", "targetHandoffIds", "decision", "authorityScope"],
        "properties": {
          "consumeId": { "type": "string", "minLength": 1 },
          "responseId": { "type": "string", "minLength": 1 },
          "targetHandoffIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "decision": { "enum": ["accepted", "amend", "split-follow-up", "rejected", "blocked"] },
          "authorityScope": { "enum": ["provisional", "final"] }
        },
        "additionalProperties": true
      }
    },
    "activeLanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["laneId", "role", "status", "currentPromptId", "authorityLevel"],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
