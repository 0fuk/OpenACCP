{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openaccp.dev/schemas/runtime-boundary.schema.json",
  "title": "OpenACCP Runtime Boundary",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactType",
    "boundaryId",
    "runtimeIdentity",
    "notificationBridge",
    "workingDirectory",
    "productRepoStatus",
    "productRepoPath",
    "baseBranch",
    "sourceRoots",
    "testEntrypoints",
    "worktreePolicy",
    "inferenceStatus",
    "inferredFrom",
    "confidence",
    "ambiguities",
    "allowedWritablePaths",
    "readOnlyPaths",
    "forbiddenPaths",
    "externalSideEffects",
    "dataRisk",
    "unresolvedOwnerInputs",
    "b2DispatchGate"
  ],
  "properties": {
    "schemaVersion": { "const": "openaccp-runtime-boundary.v1" },
    "artifactType": { "const": "runtime-boundary" },
    "boundaryId": { "type": "string", "minLength": 1 },
    "runtimeIdentity": {
      "type": "object",
      "required": ["primaryRuntime", "primaryRuntimeConfidence", "detectionEvidence", "currentThreadRef"],
      "properties": {
        "primaryRuntime": { "enum": ["codex", "claude-code", "other", "unknown"] },
        "primaryRuntimeConfidence": { "enum": ["detected", "declared", "unknown"] },
        "detectionEvidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "currentThreadRef": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "notificationBridge": {
      "type": "object",
      "required": ["state", "supportedRuntimes", "wakePolicy", "busyPolicy", "failurePolicy", "bridgeCommand"],
      "properties": {
        "state": { "enum": ["available", "unavailable", "not_configured", "not_applicable"] },
        "supportedRuntimes": { "type": "array", "items": { "enum": ["codex", "claude-code", "other", "unknown"] } },
        "wakePolicy": { "enum": ["same_runtime_native", "cross_runtime_bridge", "ledger_only", "manual_fallback"] },
        "busyPolicy": { "enum": ["queue_until_safe_checkpoint", "immediate_if_idle", "not_applicable"] },
        "failurePolicy": { "enum": ["record_parent_consume_pending", "record_pending_consume", "manual_fallback"] },
        "bridgeCommand": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "workingDirectory": { "type": "string", "minLength": 1 },
    "productRepoStatus": { "enum": ["found", "provided", "missing", "not_applicable"] },
    "productRepoPath": { "type": "string" },
    "baseBranch": { "type": "string" },
    "sourceRoots": { "type": "array", "items": { "type": "string" } },
    "testEntrypoints": { "type": "array", "items": { "type": "string" } },
    "worktreePolicy": { "enum": ["allowed", "forbidden", "unknown"] },
    "inferenceStatus": { "enum": ["not_attempted", "inferred", "partially_inferred", "ambiguous", "not_applicable"] },
    "inferredFrom": { "type": "array", "items": { "type": "string" } },
    "confidence": { "enum": ["high", "medium", "low", "unknown", "not_applicable"] },
    "ambiguities": { "type": "array", "items": { "type": "string" } },
    "allowedWritablePaths": { "type": "array", "items": { "type": "string" } },
    "readOnlyPaths": { "type": "array", "items": { "type": "string" } },
    "forbiddenPaths": { "type": "array", "items": { "type": "string" } },
    "externalSideEffects": { "enum": ["none", "local_only", "requires_approval"] },
    "dataRisk": { "enum": ["none", "low", "medium", "high", "sensitive"] },
    "unresolvedOwnerInputs": { "type": "array", "items": { "type": "string" } },
    "b2DispatchGate": {
      "type": "object",
      "required": ["state", "allowsProductWrite", "reason", "missingInputs"],
      "properties": {
        "state": { "enum": ["ready", "coordination_only", "blocked", "not_applicable"] },
        "allowsProductWrite": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 },
        "missingInputs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
