{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openaccp.dev/schemas/bridge-event.schema.json",
  "title": "OpenACCP Bridge Event",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactType",
    "eventId",
    "direction",
    "eventType",
    "status",
    "parentRuntime",
    "childRuntime",
    "runtimeRelation",
    "sourceRef",
    "targetRef",
    "createdAt",
    "expectedAction",
    "busyPolicy"
  ],
  "properties": {
    "schemaVersion": { "const": "openaccp-bridge-event.v1" },
    "artifactType": { "const": "bridge-event" },
    "eventId": { "type": "string", "minLength": 1 },
    "direction": { "enum": ["child_to_parent", "parent_to_child"] },
    "eventType": { "enum": ["parent_consume_pending", "frontier_dispatch_requested"] },
    "status": { "enum": ["queued", "wake_requested", "delivered", "adapter_unavailable", "failed", "cancelled"] },
    "parentRuntime": { "enum": ["codex", "claude-code", "other", "unknown"] },
    "childRuntime": { "enum": ["codex", "claude-code", "other", "unknown"] },
    "runtimeRelation": { "enum": ["same_runtime", "cross_runtime", "unknown"] },
    "laneId": { "type": "string" },
    "promptId": { "type": "string" },
    "responseId": { "type": "string" },
    "taskId": { "type": "string" },
    "handoffId": { "type": "string" },
    "sourceRef": { "type": "string", "minLength": 1 },
    "targetRef": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "expectedAction": { "enum": ["consume_returned_child", "start_frontier"] },
    "busyPolicy": { "enum": ["queue_until_safe_checkpoint", "immediate_if_idle", "not_applicable"] },
    "finalAuthorityNote": { "type": "string" },
    "promptRecordRef": { "type": "string" },
    "shortLauncherRef": { "type": "string" }
  },
  "additionalProperties": true
}
